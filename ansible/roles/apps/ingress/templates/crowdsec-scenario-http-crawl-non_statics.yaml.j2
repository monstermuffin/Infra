# Local override: excludes exempt FQDNs from the crawl detection bucket.
# Managed by Ansible - do not edit manually.
type: leaky
name: crowdsecurity/http-crawl-non_statics
description: "Detect aggressive crawl on non static resources"
filter: >-
  evt.Meta.log_type in ['http_access-log', 'http_error-log'] &&
  evt.Parsed.static_ressource == 'false' &&
  evt.Parsed.verb in ['GET', 'HEAD'] &&
  evt.Parsed.target_fqdn not in {{ ingress_crowdsec_scenario_exempt_fqdns | to_json }}
distinct: "evt.Parsed.file_name"
leakspeed: 0.5s
capacity: 40
cache_size: 5
groupby: "evt.Meta.source_ip + '/' + evt.Parsed.target_fqdn"
blackhole: 1m
labels:
  confidence: 1
  spoofable: 0
  classification:
    - attack.T1595
  behavior: "http:crawl"
  service: http
  label: "Aggressive Crawl"
  remediation: true
